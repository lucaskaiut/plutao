# Copie para web/.env.local (arquivos .env* estão no .gitignore do Next.js):
# cp web/env.docker.example web/.env.local

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8080

# URL base da API Laravel **com** sufixo /api (usada só no servidor Next — BFF / server actions).
# No Docker (serviço web → nginx): http://nginx/api
API_BASE_URL=http://localhost:8080/api
